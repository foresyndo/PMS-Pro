rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Deny All net
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Checking profile data
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Properties metadata
    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(propertyId);

      // Sub-collection Units inside properties
      match /units/{unitId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isValidId(unitId);
      }
    }

    // Tenants directory representation
    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(tenantId);
    }

    // Reservations catalog
    match /reservations/{reservationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(reservationId);
    }

    // Lease agreements
    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(contractId);
    }

    // Invoices generated
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(invoiceId);
    }

    // Payments registered
    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(paymentId);
    }

    // Operational expenses logged
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(expenseId);
    }

    // Maintenance logs
    match /maintenance/{maintenanceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(maintenanceId);
    }

    // Room inventories
    match /inventory/{inventoryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(inventoryId);
    }

    // System notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(notificationId);
    }

    // Consolidated reports
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(reportId);
    }
  }
}
